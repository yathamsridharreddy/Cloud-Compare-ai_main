# ==================================================================
# CloudCompare AI — Environment Configuration
# ==================================================================
# Copy this file to .env and fill in the values before running.
# NEVER commit your actual .env file to version control.
# ==================================================================

# Groq API Configuration
GROK_API_KEYS=your-groq-api-key-here

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-min-64-chars

# Database Configuration
DB_HOST=localhost
DB_NAME=cloudcompare
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# Docker Image (used by docker-compose)
DOCKER_IMAGE=raghavendra2006/cloudcompare-ai:latest
